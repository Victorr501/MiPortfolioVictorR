@* ── src/MiPortfolioVictorR.Client/Pages/Projects.razor ── *@
@page "/proyectos"
@inject ProjectService ProjectService
@inject LanguageService LangService
@implements IDisposable

<PageTitle>@LangService.Get("Proyectos", "Projects") — Víctor Rubín Rubio</PageTitle>

<div class="page-container">

    @* ── ESTILOS INYECTADOS DIRECTAMENTE ── *@
    <style>
            .contenedor-filtros {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                margin-top: 2.5rem !important; /* Separación forzada de la línea */
                margin-bottom: 2rem !important;
            }

            .boton-filtro {
                background: var(--color-badge-bg);
                color: var(--color-badge-text);
                border: 0.5px solid var(--color-badge-border);
                font-size: .8rem;
                padding: 6px 16px;
                border-radius: 20px;
                cursor: pointer;
                opacity: 0.5;
                transition: all 0.2s ease;
                font-family: inherit;
                font-weight: 500;
                outline: none;
            }

                .boton-filtro:hover {
                    opacity: 0.8;
                    transform: translateY(-1px);
                }

            .boton-filtro--activo {
                opacity: 1 !important;
                font-weight: 700;
                box-shadow: 0 2px 4px rgba(146, 64, 14, 0.15);
            }
    </style>

    @* ── HEADER ── *@
    <section class="proj-page__header">
        <div class="section__label">@LangService.Get("Trabajo", "Work")</div>
        <h1 class="proj-page__title">@LangService.Get("Proyectos", "Projects")</h1>
        <p class="proj-page__sub">@LangService.Get("Estos son los resultados de mi aprendizaje, plasmados en cada proyecto. Explóralos, aprende y úsalos si quieres.", "These are the results of my learning, reflected in each project. Explore them, learn from them and use them if you like.")</p>
    </section>

    @* ── FILTROS DE CATEGORÍA ── *@
    <section class="contenedor-filtros">
        <button class="boton-filtro @(string.IsNullOrEmpty(_selectedCategory) ? "boton-filtro--activo" : "")"
                @onclick="() => FilterByCategory(null)">
            @LangService.Get("Todos", "All")
        </button>

        @foreach (var cat in ProjectService.GetDistinctCategories())
        {
            <button class="boton-filtro @(_selectedCategory == cat ? "boton-filtro--activo" : "")"
                    @onclick="() => FilterByCategory(cat)">
                @cat
            </button>
        }
    </section>

    @* ── LISTA DE PROYECTOS ── *@
    <section class="section">
        <div class="proj-list">
            @{
                // NUEVO: Obtenemos los proyectos filtrados antes de paginar
                var filteredProjects = string.IsNullOrEmpty(_selectedCategory)
                                        ? ProjectService.GetProjects()
                                        : ProjectService.GetByCategory(_selectedCategory);

                var paged = filteredProjects.Skip((_page - 1) * PageSize).Take(PageSize).ToList();
            }

            @for (int i = 0; i < paged.Count; i++)
            {
                var project = paged[i];
                var globalIndex = (_page - 1) * PageSize + i + 1;
                <div class="proj-row @(project.IsFeatured ? "proj-row--featured" : "")">
                    <span class="proj-row__num">@globalIndex.ToString("00")</span>
                    <div class="proj-row__body">
                        <div class="proj-row__top">
                            <h2 class="proj-row__title">@LangService.Get(project.Title, project.TitleEn)</h2>
                            @if (project.IsFeatured)
                            {
                                <span class="badge-wood">@LangService.Get("Destacado", "Featured")</span>
                            }
                        </div>
                        <p class="proj-row__desc">@LangService.Get(project.Description, project.DescriptionEn)</p>
                        <div class="proj-row__tags">
                            @foreach (var tag in project.Tags)
                            {
                                <span class="badge-wood">@tag</span>
                            }
                        </div>
                    </div>
                    <div class="proj-row__links">
                        <a href="@project.GitHubUrl" target="_blank" rel="noopener noreferrer" class="proj-row__link">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                <path d="M9 18c-4.51 2-5-2-7-2" />
                            </svg>
                            GitHub
                        </a>
                        @if (!string.IsNullOrEmpty(project.LiveUrl))
                        {
                            <a href="@project.LiveUrl" target="_blank" rel="noopener noreferrer" class="proj-row__link">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                                </svg>
                                @LangService.Get("Ver web", "View site")
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(project.GitHubUrlBackend))
                        {
                            <a href="@project.GitHubUrlBackend" target="_blank" rel="noopener noreferrer" class="proj-row__link">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                                    <path d="M9 18c-4.51 2-5-2-7-2" />
                                </svg>
                                Backend
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(project.YouTubeUrl))
                        {
                            <a href="@project.YouTubeUrl" target="_blank" rel="noopener noreferrer" class="proj-row__link proj-row__link--yt">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17" />
                                    <path d="m10 15 5-3-5-3z" />
                                </svg>
                                YouTube
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── PAGINACIÓN ── *@
        @{
            // NUEVO: La paginación ahora cuenta los proyectos filtrados, no todos
            var total = filteredProjects.Count;
            var totalPages = (int)Math.Ceiling(total / (double)PageSize);
        }

        @if (totalPages > 1)
        {
            <div class="proj-pagination">
                <button class="proj-pagination__btn" disabled="@(_page == 1)" @onclick="PrevPage">← @LangService.Get("Anterior", "Previous")</button>
                <div class="proj-pagination__pages">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        var pageNum = p;
                        <button class="proj-pagination__num @(_page == pageNum ? "proj-pagination__num--active" : "")" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    }
                </div>
                <button class="proj-pagination__btn" disabled="@(_page == totalPages)" @onclick="NextPage">@LangService.Get("Siguiente", "Next") →</button>
            </div>
        }
    </section>
</div>

@code {
    private const int PageSize = 10;
    private int _page = 1;

    // NUEVO: Estado para guardar la categoría seleccionada
    private string? _selectedCategory = null;

    // NUEVO: Método para cambiar de categoría y resetear la página a 1
    private void FilterByCategory(string? category)
    {
        _selectedCategory = category;
        _page = 1;
    }

    private void PrevPage() { if (_page > 1) _page--; }

    private void NextPage()
    {
        // NUEVO: Actualizamos NextPage para que respete el total de páginas filtradas
        var currentList = string.IsNullOrEmpty(_selectedCategory)
                            ? ProjectService.GetProjects()
                            : ProjectService.GetByCategory(_selectedCategory);

        var total = currentList.Count;
        var totalPages = (int)Math.Ceiling(total / (double)PageSize);

        if (_page < totalPages) _page++;
    }

    private void GoToPage(int p) => _page = p;

    protected override void OnInitialized()
    {
        LangService.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= StateHasChanged;
    }
}