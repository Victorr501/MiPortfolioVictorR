@* ── src/MiPortfolioVictorR.Client/Pages/Experience.razor ── *@
@page "/experiencia"
@inject ExperienceService ExperienceService
@inject LanguageService LangService
@implements IDisposable

<PageTitle>@LangService.Get("Experiencia", "Experience") — Víctor Rubín Rubio</PageTitle>

<div class="page-container">

    @* ── HEADER ── *@
    <section class="exp-page__header">
        <div class="section__label">@LangService.Get("Trayectoria", "Career")</div>
        <h1 class="exp-page__title">@LangService.Get("Experiencia laboral", "Work Experience")</h1>
        <p class="exp-page__sub">@LangService.Get("Mi recorrido profesional, desde desarrollo de software hasta atención al cliente y voluntariado.", "My professional journey, from software development to customer service and volunteering.")</p>
    </section>

    @* ── DEVELOPER ── *@
    <section class="section">
        <div class="exp-block__label">
            <span class="exp-block__dot exp-block__dot--dev"></span>
            @LangService.Get("Como desarrollador", "As a developer")
        </div>
        <div class="exp-timeline">
            @foreach (var exp in ExperienceService.GetByType(ExperienceType.Developer))
            {
                <div class="exp-card">
                    <div class="exp-card__aside">
                        <span class="exp-card__period">@exp.Period</span>
                        <span class="exp-card__location">@exp.Location</span>
                    </div>
                    <div class="exp-card__body">
                        <div class="exp-card__header">
                            <h2 class="exp-card__role">@LangService.Get(exp.Role, exp.RoleEn)</h2>
                            <span class="exp-card__company">@exp.Company</span>
                        </div>
                        <ul class="exp-card__list">
                            @{
                                var descs = LangService.IsEnglish && exp.DescriptionsEn?.Count > 0
                                    ? exp.DescriptionsEn
                                    : exp.Descriptions;
                            }
                            @foreach (var desc in descs)
                            {
                                <li>@desc</li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </section>

    @* ── GENÉRICA ── *@
    <section class="section">
        <div class="exp-block__label">
            <span class="exp-block__dot exp-block__dot--generic"></span>
            @LangService.Get("Experiencia genérica", "General Experience")
        </div>
        <div class="exp-timeline">
            @foreach (var exp in ExperienceService.GetByType(ExperienceType.Generic))
            {
                <div class="exp-card">
                    <div class="exp-card__aside">
                        <span class="exp-card__period">@exp.Period</span>
                        <span class="exp-card__location">@exp.Location</span>
                    </div>
                    <div class="exp-card__body">
                        <div class="exp-card__header">
                            <h2 class="exp-card__role">@LangService.Get(exp.Role, exp.RoleEn)</h2>
                            <span class="exp-card__company">@exp.Company</span>
                        </div>
                        <ul class="exp-card__list">
                            @{
                                var descs = LangService.IsEnglish && exp.DescriptionsEn?.Count > 0
                                    ? exp.DescriptionsEn
                                    : exp.Descriptions;
                            }
                            @foreach (var desc in descs)
                            {
                                <li>@desc</li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </section>

    @* ── VOLUNTARIADOS ── *@
    <section class="section">
        <div class="exp-block__label">
            <span class="exp-block__dot exp-block__dot--vol"></span>
            @LangService.Get("Voluntariados", "Volunteering")
        </div>
        <div class="exp-timeline">
            @foreach (var exp in ExperienceService.GetByType(ExperienceType.Volunteer))
            {
                <div class="exp-card">
                    <div class="exp-card__aside">
                        <span class="exp-card__period">@exp.Period</span>
                        <span class="exp-card__location">@exp.Location</span>
                    </div>
                    <div class="exp-card__body">
                        <div class="exp-card__header">
                            <h2 class="exp-card__role">@LangService.Get(exp.Role, exp.RoleEn)</h2>
                            <span class="exp-card__company">@exp.Company</span>
                        </div>
                        <ul class="exp-card__list">
                            @{
                                var descs = LangService.IsEnglish && exp.DescriptionsEn?.Count > 0
                                    ? exp.DescriptionsEn
                                    : exp.Descriptions;
                            }
                            @foreach (var desc in descs)
                            {
                                <li>@desc</li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </section>

</div>

@code {
    protected override void OnInitialized()
    {
        LangService.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= StateHasChanged;
    }
}
