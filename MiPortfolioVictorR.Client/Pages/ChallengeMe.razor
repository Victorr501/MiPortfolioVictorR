@* ── src/MiPortfolioVictorR.Client/Pages/ChallengeMe.razor ── *@
@page "/challengeme"
@inject ChallengeMeService ChallengeMeService

<PageTitle>ChallengeMe! — Proyecto · Víctor Rubín Rubio</PageTitle>

<div class="page-container">

    @* ── HERO ── *@
    <section class="pfc-hero">
        <div class="pfc-hero__meta">
            <span class="badge-wood">Proyecto Personal</span>
            <span class="badge-wood">En desarrollo · 2026</span>
        </div>
        <h1 class="pfc-hero__title">ChallengeMe!</h1>
        <p class="pfc-hero__desc">
            Aplicación web de ocio que propone cada día un reto personalizado según tus
            gustos e intereses. Completa retos, acumula puntos, mantén tu racha y compite
            en el ranking global.
        </p>
        <div class="pfc-hero__links">
            <a class="btn-wood-primary" href="https://challengme-web-h9b6hmftgtc7cmch.spaincentral-01.azurewebsites.net" target="_blank" rel="noopener noreferrer">
                Pagina web
            </a>
            <a class="btn-wood-outline" href="https://github.com/Victorr501/ChallengMe" target="_blank" rel="noopener noreferrer">
                GitHub - API - Web
            </a>
            <a class="btn-wood-outline" href="https://github.com/Victorr501/ChallengMe-iOS" target="_blank" rel="noopener noreferrer">
                GitHub - iOS
            </a>
            <a class="btn-wood-outline" href="https://github.com/Victorr501/ChallengMe-Android" target="_blank" rel="noopener noreferrer">
                GitHub - Android
            </a>
        </div>
    </section>

    @* ── FUNCIONALIDADES ── *@
    <section class="section">
        <div class="section__label">Qué hace</div>
        <h2 class="section__title">Funcionalidades</h2>
        <div class="pfc-features">

            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 8v4l3 3" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">Reto diario personalizado</h3>
                <p class="pfc-feature__desc">Una IA genera cada día un reto adaptado a tus intereses y nivel de dificultad. Puedes regenerarlo hasta dos veces al día.</p>
            </div>

            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">Rachas y puntos</h3>
                <p class="pfc-feature__desc">Completa retos consecutivos para construir una racha. Cada reto completado suma puntos y escala posiciones en el ranking global.</p>
            </div>

            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">Evidencia fotográfica</h3>
                <p class="pfc-feature__desc">Al completar un reto puedes subir una foto como prueba o recuerdo personal de tu logro del día.</p>
            </div>

            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10" />
                        <line x1="12" y1="20" x2="12" y2="4" />
                        <line x1="6" y1="20" x2="6" y2="14" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">Ranking global</h3>
                <p class="pfc-feature__desc">Tabla clasificatoria actualizada diariamente con los usuarios más activos. Consulta tu posición y compara tu progreso con otros.</p>
            </div>

        </div>
    </section>

    @* ── TECNOLOGÍAS ── *@
    <section class="section">
        <div class="section__label">Stack</div>
        <h2 class="section__title">Tecnologías usadas</h2>
        <div class="pfc-stack">
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Base de datos SQL</span>
                <span class="pfc-stack__tech">Azure SQL · Dapper</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Base de datos NoSQL</span>
                <span class="pfc-stack__tech">Azure Cosmos DB</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Backend</span>
                <span class="pfc-stack__tech">C# · ASP.NET Core · Azure App Service</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Inteligencia artificial</span>
                <span class="pfc-stack__tech">Google Gemini API</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Almacenamiento</span>
                <span class="pfc-stack__tech">Azure Blob Storage</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Autenticación</span>
                <span class="pfc-stack__tech">Azure Entra ID · Microsoft.Identity.Web</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Tareas programadas</span>
                <span class="pfc-stack__tech">Azure Functions</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Frontend web</span>
                <span class="pfc-stack__tech">Blazor WASM</span>
            </div>
        </div>
    </section>

    @* ── MOTIVACIÓN ── *@
    <section class="section">
        <div class="section__label">Por qué lo hago</div>
        <h2 class="section__title">Motivación</h2>
        <blockquote class="pfc-quote">
            ChallengeMe! nace de las ganas de salir de la rutina sin presión.
            La idea es sencilla: un pequeño reto cada día, adaptado a lo que te gusta,
            que te saque del modo automático. A la vez es una oportunidad de profundizar
            en el stack Microsoft Azure y en la integración de IA generativa en aplicaciones reales.
        </blockquote>
    </section>

    @* ── ARQUITECTURA ── *@
    <section class="section">
        <div class="section__label">Diseño técnico</div>
        <h2 class="section__title">Arquitectura</h2>
        <div class="pfc-stack">
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 1 · API</span>
                <span class="pfc-stack__tech">Controllers · DTOs · Middleware de errores</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 2 · Servicios</span>
                <span class="pfc-stack__tech">RetoService · UsuarioService · PuntosService</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 3 · Repositorios</span>
                <span class="pfc-stack__tech">RetoRepository · UsuarioRepository · RankingRepository (Dapper)</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 4 · Gemini</span>
                <span class="pfc-stack__tech">GeminiClient · PromptBuilder</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 5 · Auth</span>
                <span class="pfc-stack__tech">AuthService · AzureAdOptions</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Capa 6 · Functions</span>
                <span class="pfc-stack__tech">GenerarRetoDiario (00:00) · ActualizarRanking (24h)</span>
            </div>
        </div>
    </section>

    @* ── DIARIO DE DESARROLLO ── *@
    <section class="section">
        <div class="section__label">Diario de desarrollo</div>
        <h2 class="section__title">Actualizaciones</h2>
        <div class="pfc-progress">
            <div class="pfc-progress__bar">
                <div class="pfc-progress__fill" style="width: 1%"></div>
            </div>
            <span class="pfc-progress__label">Proyecto en desarrollo 1%</span>
        </div>

        @if (!ChallengeMeService.GetUpdates().Any())
        {
            <div class="pfc-updates">
                <div class="pfc-update">
                    <div class="pfc-update__body">
                        <h3 class="pfc-update__title">Aún sin actualizaciones</h3>
                        <p class="pfc-update__desc">El desarrollo de ChallengeMe! no ha comenzado todavía. Esta sección se irá completando con el diario de progreso una vez arranque el proyecto.</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="pfc-updates">
                @foreach (var update in ChallengeMeService.GetUpdates())
                {
                    <div class="pfc-update">
                        <div class="pfc-update__date">
                            <span class="pfc-update__day">@update.Date.Day.ToString("00")</span>
                            <span class="pfc-update__month">@update.Date.ToString("MMM", new System.Globalization.CultureInfo("es-ES"))</span>
                            <span class="pfc-update__year">@update.Date.Year</span>
                        </div>
                        <div class="pfc-update__body">
                            <h3 class="pfc-update__title">@update.Title</h3>
                            <p class="pfc-update__desc">@update.Description</p>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

</div>
