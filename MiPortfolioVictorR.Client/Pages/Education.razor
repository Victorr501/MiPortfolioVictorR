@* ── src/MiPortfolioVictorR.Client/Pages/Education.razor ── *@
@page "/estudios"
@inject EducationService EducationService

<PageTitle>Estudios — Víctor Rubín Rubio</PageTitle>

<div class="page-container">

    @* ── HEADER ── *@
    <section class="edu-page__header">
        <div class="section__label">Formación</div>
        <h1 class="edu-page__title">Estudios y cursos</h1>
        <p class="edu-page__sub">Mi recorrido académico y los cursos que he completado para seguir creciendo.</p>
    </section>

    @* ── FORMACIÓN ACADÉMICA ── *@
    <section class="section">
        <div class="section__label">Académico</div>
        <h2 class="section__title">Formación reglada</h2>
        <div class="edu-academic">
            @foreach (var edu in EducationService.GetEducation())
            {
                <div class="edu-academic__item">
                    <div class="edu-academic__period">@edu.Period</div>
                    <div class="edu-academic__body">
                        <h3 class="edu-academic__title">@edu.Title</h3>
                        <p class="edu-academic__center">@edu.Center · @edu.Location</p>
                    </div>
                </div>
            }
        </div>
    </section>

    @* ── CURSOS ── *@
    <section class="section">
        <div class="section__label">Aprendizaje continuo</div>
        <h2 class="section__title">Cursos completados</h2>

        @foreach (var platform in EducationService.GetCourses().Select(c => c.Platform).Distinct())
        {
            var allCourses = EducationService.GetCourses().Where(c => c.Platform == platform).ToList();
            var pageSize = 5;
            var totalPages = (int)Math.Ceiling(allCourses.Count / (double)pageSize);
            var currentPage = GetPage(platform);
            var paged = allCourses.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

            <div class="courses-group">
                <h3 class="courses-group__title">@platform</h3>
                <div class="courses-list">
                    @foreach (var course in paged)
                    {
                        <div class="course-item">
                            <div class="course-item__left">
                                <span class="course-item__name">@course.Name</span>
                                @if (!string.IsNullOrEmpty(course.CertificateCode))
                                {
                                    <span class="course-item__code">@course.CertificateCode</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(course.Url))
                            {
                                <a href="@course.Url" target="_blank" rel="noopener noreferrer" class="course-item__link">
                                    Ver certificado →
                                </a>
                            }
                        </div>
                    }
                </div>

                @* ── PAGINACIÓN (solo si hay más de 5) ── *@
                @if (totalPages > 1)
                {
                    var capturedPlatform = platform;
                    <div class="pagination">
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            var pageNum = p;
                            var isActive = pageNum == currentPage;
                            <span class="pagination__btn @(isActive ? "pagination__btn--active" : "")"
                                  @onclick="() => SetPage(capturedPlatform, pageNum)">
                                @pageNum
                            </span>
                        }
                    </div>
                }
                
            </div>
        }
    </section>

</div>

@code {
    private readonly Dictionary<string, int> _pages = new();

    private int GetPage(string platform) =>
        _pages.TryGetValue(platform, out var p) ? p : 1;

    private void SetPage(string platform, int page) =>
        _pages[platform] = page;
}

<style>
    .pagination {
        display: flex;
        gap: .25rem;
        margin-top: 1rem;
        justify-content: center;
    }

    .pagination__btn {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        font-weight: 500;
        color: #78625A;
        background: transparent;
        border: 0.5px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        transition: all .15s;
        user-select: none;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

        .pagination__btn:hover {
            border-color: #E7DDD0;
            color: #92400E;
        }

    .pagination__btn--active {
        background: #92400E;
        color: #fff !important;
        border-color: #92400E !important;
        pointer-events: none;
    }
</style>