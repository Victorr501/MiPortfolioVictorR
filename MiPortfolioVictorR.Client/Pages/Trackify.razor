@* ── src/MiPortfolioVictorR.Client/Pages/Trackify.razor ── *@
@page "/trackify"
@inject TrackifyService TrackifyService
@inject LanguageService LangService
@implements IDisposable

<PageTitle>Trackify — PFC · Víctor Rubín Rubio</PageTitle>

<div class="page-container">

    @* ── HERO DEL PFC ── *@
    <section class="pfc-hero">
        <div class="pfc-hero__meta">
            <span class="badge-wood">@LangService.Get("Proyecto Fin de Ciclo", "Final Degree Project")</span>
            <span class="badge-wood">DAM · 2025</span>
        </div>
        <h1 class="pfc-hero__title">Trackify</h1>
        <p class="pfc-hero__desc">
            @LangService.Get(
                "Trackify organiza hábitos diarios y semanales, envía recordatorios automáticos y muestra el progreso con estadísticas claras para que mantener la constancia sea más sencillo.",
                "Trackify organizes daily and weekly habits, sends automatic reminders and displays progress with clear statistics to make consistency easier to maintain. "
            )
        </p>
        <div class="pfc-hero__links">
            <a class="btn-wood-primary" href="https://github.com/Victorr501/TRACKIFY_FrontEnd" target="_blank" rel="noopener noreferrer">
                Frontend
            </a>
            <a class="btn-wood-outline" href="https://github.com/Victorr501/TRACKIFY_BackEnd" target="_blank" rel="noopener noreferrer">
                Backend
            </a>
            <a class="btn-wood-outline" href="https://www.youtube.com/watch?v=yB56afseJ-4&t=2s" target="_blank" rel="noopener noreferrer">
                @LangService.Get("Ver vídeo", "Watch video")
            </a>
        </div>
    </section>

    @* ── FUNCIONALIDADES ── *@
    <section class="section">
        <div class="section__label">@LangService.Get("Qué hace", "What it does")</div>
        <h2 class="section__title">@LangService.Get("Funcionalidades", "Features")</h2>
        <div class="pfc-features">
            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <path d="M16 2v4M8 2v4M3 10h18" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">@LangService.Get("Registro flexible", "Flexible tracking")</h3>
                <p class="pfc-feature__desc">@LangService.Get("El usuario define hábitos diarios o semanales con recordatorios personalizados según lo que quiera lograr.", "Users define daily or weekly habits with personalized reminders based on their goals.")</p>
            </div>
            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">@LangService.Get("Rachas entre amigos", "Friend streaks")</h3>
                <p class="pfc-feature__desc">@LangService.Get("Hasta 5 amigos pueden compartir una misma racha y progresar juntos hacia sus objetivos.", "Up to 5 friends can share the same streak and progress together toward their goals.")</p>
            </div>
            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">@LangService.Get("Gestión de rachas", "Streak management")</h3>
                <p class="pfc-feature__desc">@LangService.Get("Trackify contabiliza los días consecutivos cumplidos para reforzar la motivación y la constancia.", "Trackify counts consecutive days completed to reinforce motivation and consistency.")</p>
            </div>
            <div class="pfc-feature">
                <div class="pfc-feature__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10" />
                        <line x1="12" y1="20" x2="12" y2="4" />
                        <line x1="6" y1="20" x2="6" y2="14" />
                    </svg>
                </div>
                <h3 class="pfc-feature__title">@LangService.Get("Gráficos de progreso", "Progress charts")</h3>
                <p class="pfc-feature__desc">@LangService.Get("Visualizaciones interactivas que muestran la evolución del usuario y permiten detectar tendencias.", "Interactive visualizations that show user evolution and reveal trends over time.")</p>
            </div>
        </div>
    </section>

    @* ── TECNOLOGÍAS ── *@
    <section class="section">
        <div class="section__label">Stack</div>
        <h2 class="section__title">@LangService.Get("Tecnologías usadas", "Technologies used")</h2>
        <div class="pfc-stack">
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">@LangService.Get("Base de datos", "Database")</span>
                <span class="pfc-stack__tech">MySQL · DBeaver</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">Backend</span>
                <span class="pfc-stack__tech">Python · FastAPI</span>
            </div>
            <div class="pfc-stack__item">
                <span class="pfc-stack__layer">@LangService.Get("Frontend móvil", "Mobile frontend")</span>
                <span class="pfc-stack__tech">React Native · Android @LangService.Get("e", "&") iOS</span>
            </div>
        </div>
    </section>

    @* ── MOTIVACIÓN ── *@
    <section class="section">
        <div class="section__label">@LangService.Get("Por qué lo hice", "Why I built it")</div>
        <h2 class="section__title">@LangService.Get("Motivación", "Motivation")</h2>
        <blockquote class="pfc-quote">
            @LangService.Get(
                "Trackify nace de mi interés por el desarrollo personal y la importancia de construir hábitos sólidos. Experiencias cercanas me mostraron cómo una herramienta tecnológica puede contribuir al bienestar diario, por lo que este proyecto une mis ganas de aprender con la intención de crear algo útil para más personas.",
                "Trackify was born from my interest in personal development and the importance of building solid habits. Close experiences showed me how a technology tool can contribute to daily wellbeing, so this project combines my eagerness to learn with the intention of creating something useful for others."
            )
        </blockquote>
    </section>

    @* ── BLOG DE ACTUALIZACIONES ── *@
    <section class="section">
        <div class="section__label">@LangService.Get("Diario de desarrollo", "Dev diary")</div>
        <h2 class="section__title">@LangService.Get("Actualizaciones", "Updates")</h2>
        <div class="pfc-progress">
            <div class="pfc-progress__bar">
                <div class="pfc-progress__fill" style="width: 100%"></div>
            </div>
            <span class="pfc-progress__label">@LangService.Get("Proyecto completado · 100%", "Project completed · 100%")</span>
        </div>

        @{
            var updates = TrackifyService.GetUpdates();
            var pageSize = 5;
            var totalPages = (int)Math.Ceiling(updates.Count / (double)pageSize);
            var paged = updates.Skip((_updatesPage - 1) * pageSize).Take(pageSize).ToList();
        }

        <div class="pfc-updates">
            @foreach (var update in paged)
            {
                <div class="pfc-update">
                    <div class="pfc-update__date">
                        <span class="pfc-update__day">@update.Date.Day.ToString("00")</span>
                        <span class="pfc-update__month">@update.Date.ToString(LangService.IsEnglish ? "MMM" : "MMM", LangService.IsEnglish ? new System.Globalization.CultureInfo("en-GB") : new System.Globalization.CultureInfo("es-ES"))</span>
                        <span class="pfc-update__year">@update.Date.Year</span>
                    </div>
                    <div class="pfc-update__body">
                        <h3 class="pfc-update__title">@LangService.Get(update.Title, update.TitleEn)</h3>
                        <p class="pfc-update__desc">@LangService.Get(update.Description, update.DescriptionEn)</p>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="pagination">
                @for (int p = 1; p <= totalPages; p++)
                {
                    var pageNum = p;
                    <span class="pagination__btn @(pageNum == _updatesPage ? "pagination__btn--active" : "")"
                          @onclick="() => { _updatesPage = pageNum; }">
                        @pageNum
                    </span>
                }
            </div>
        }
    </section>

</div>

<style>
    .pagination {
        display: flex;
        gap: .25rem;
        margin-top: 1rem;
        justify-content: center;
    }

    .pagination__btn {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        font-weight: 500;
        color: #78625A;
        background: transparent;
        border: 0.5px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        transition: all .15s;
        user-select: none;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

        .pagination__btn:hover {
            border-color: #E7DDD0;
            color: #92400E;
        }

    .pagination__btn--active {
        background: #92400E;
        color: #fff !important;
        border-color: #92400E !important;
        pointer-events: none;
    }
</style>

@code {
    private int _updatesPage = 1;

    protected override void OnInitialized()
    {
        LangService.OnLanguageChanged += StateHasChanged;
    }

    public void Dispose()
    {
        LangService.OnLanguageChanged -= StateHasChanged;
    }
}
